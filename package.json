{
  "name": "holomem",
  "version": "1.0.0",
  "private": true,
  "description": "HoloMem — Cryptographic Memory Mesh for Autonomous Collaborative Agent Swarms",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/sdk-ts && npm run build -w apps/api",
    "demo": "npm run demo -w packages/core",
    "demo:mock": "npm run demo:mock -w packages/core",
    "api:dev": "npm run dev -w apps/api",
    "api:start": "npm run start -w apps/api",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:migrate": "npm run db:migrate -w apps/api",
    "test:integration": "npm run test:integration -w apps/api"
  },
  "engines": {
    "node": "22.10.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
